# Caddy v2 — API must be handled BEFORE try_files / file_server,
# otherwise /api/* returns index.html and the app shows a JSON parse error.

your-domain.com {
	encode gzip

	# Port must match gunicorn in moja-strumica-web.service (e.g. 5052, not 5000).
	@api path /api/*
	handle @api {
		reverse_proxy 127.0.0.1:5052
	}

	handle {
		root * /home/andrej/moja-strumica/dist
		try_files {path} /index.html
		file_server
	}
}
